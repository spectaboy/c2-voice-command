        </collision>
        <visual name="visual">
          <geometry><box><size>0.5 30 4</size></box></geometry>
          <material>
            <ambient>0.6 0.55 0.45 1</ambient>
            <diffuse>0.55 0.50 0.40 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!--  GATE / ENTRY CHECKPOINT (west wall, 10m gap)                -->
    <!-- ============================================================ -->
    <model name="gate_post_left">
      <static>true</static>
      <pose>-60 -10 2.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1 1 5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1 1 5</size></box></geometry>
          <material>
            <ambient>0.4 0.35 0.3 1</ambient>
            <diffuse>0.4 0.35 0.3 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="gate_post_right">
      <static>true</static>
      <pose>-60 10 2.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1 1 5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1 1 5</size></box></geometry>
          <material>
            <ambient>0.4 0.35 0.3 1</ambient>
            <diffuse>0.4 0.35 0.3 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!--  MAIN BUILDING — 2-story command structure                   -->
    <!-- ============================================================ -->
    <model name="command_building">
      <static>true</static>
      <pose>20 10 4 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>20 15 8</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>20 15 8</size></box></geometry>
