      <static>true</static>
      <pose>25 14 9.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>5 4 3</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>5 4 3</size></box></geometry>
