    <!-- ============================================================ -->
    <!--  WATCH TOWERS — 4 corners                                    -->
    <!-- ============================================================ -->
    <model name="tower_ne">
      <static>true</static>
      <pose>57 37 4 0 0 0</pose>
      <link name="link">
        <!-- Tower base -->
        <collision name="base_col">
