    <!-- Landing pad "H" marker — center cross -->
    <model name="pad_marker_h">
      <static>true</static>
      <pose>-40 0 0.12 0 0 0</pose>
      <link name="link">
        <visual name="cross_ns">
          <geometry><box><size>0.3 6 0.01</size></box></geometry>
          <material>
            <ambient>0.9 0.9 0.2 1</ambient>
            <diffuse>0.95 0.95 0.3 1</diffuse>
          </material>
        </visual>
        <visual name="cross_ew">
          <geometry><box><size>4 0.3 0.01</size></box></geometry>
          <material>
            <ambient>0.9 0.9 0.2 1</ambient>
            <diffuse>0.95 0.95 0.3 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!--  FUEL DEPOT — sensitive area (no-strike zone challenge)      -->
    <!-- ============================================================ -->
    <model name="fuel_tank_1">
      <static>true</static>
      <pose>-30 -32 2 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>2</radius><length>4</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>2</radius><length>4</length></cylinder></geometry>
          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.75 0.75 0.75 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="fuel_tank_2">
      <static>true</static>
      <pose>-24 -32 2 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>2</radius><length>4</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>2</radius><length>4</length></cylinder></geometry>
          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.75 0.75 0.75 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!--  SPAWN POSE — vehicles spawn at the landing pad              -->
    <!-- ============================================================ -->
    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <latitude_deg>32.990</latitude_deg>
      <longitude_deg>-106.975</longitude_deg>
      <elevation>1400</elevation>
      <heading_deg>0</heading_deg>
    </spherical_coordinates>

  </world>
</sdf>
